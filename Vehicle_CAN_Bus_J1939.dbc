VAL_ 2565876513 Crash_Cks 1 "Checksum = ((Checksum >> 4) + Checksum) & 0Fh" 0 "Checksum = (Byte1 + Byte2 + Byte3 + Byte4 + Byte5 + Byte6 + Byte7 + (message counter & 0Fh) + message ID low byte + message ID mid low byte + message ID mid high byte + message ID high byte)" ;
