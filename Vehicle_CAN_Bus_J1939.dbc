VAL_TABLE_ ThermMngtSysHVILSts 3 "Not Available" 2 "Error" 1 "HVIL Open" 0 "HVIL Closed" ;
VAL_TABLE_ ThermMngtSysCooltLvl 3 "Not Available" 2 "Error" 1 "Coolant Level is sufficient" 0 "Coolant Level is not sufficient" ;
VAL_TABLE_ ThermManagSysMode_table 15 "Not Available" 14 "Faulted" 13 "Reserved" 12 "Reserved" 11 "Reserved" 10 "Reserved" 9 "Reserved" 8 "Reserved" 7 "Reserved" 6 "Reserved" 5 "Reserved" 4 "Drying" 3 "Heating" 2 "Cooling" 1 "Circulating" 0 "Off" ;
VAL_TABLE_ HVESS_Total_Accumulated_Charge 1 "100 Ah/bit" 0 "Description for the value '0x0'" ;
VAL_TABLE_ HVESS_Total_Energy_Throughput 1 "100 Watt-hour per bit" 0 "Description for the value '0x0'" ;
VAL_TABLE_ HVESS_State_of_Health 0 "0.4% per bit" ;
VAL_TABLE_ HVBLSRCR 3 "11b = Don't care/take no action" 2 "10b = Reserved" 1 "01b = Connection Requested" 0 "00b = Connection not Requested" ;
VAL_TABLE_ HVBHSRCR 3 "11b = Don't care/take no action" 2 "10b = Reserved" 1 "01b = Connection Requested" 0 "00b = Connection not Requested" ;
VAL_TABLE_ HOC 3 "11b = Don't care/Take no action" 2 "10b = Error" 1 "01b = Consent given" 0 "00b = Consent revoked" ;
VAL_TABLE_ HEICC 3 "11b = Don't care/Take no action" 2 "10b = Reserved" 1 "01b = Enable charging" 0 "00b = Disable charging" ;
VAL_TABLE_ HCBC 3 "11b = Don't care/Take no action" 2 "10b = Reserved" 1 "01b = Cell Balancing requested" 0 "00b = Cell Balancing not req" ;
VAL_TABLE_ HVBPITC 3 "11b = Don't care/Take no action" 2 "10b = Inhibit Passive Iso Test" 1 "01b = Passive Iso Test req" 0 "00b = Passive Iso Test not req" ;
VAL_TABLE_ HVBAITC 3 "11b = Don't care/Take no action" 2 "10b = Inhibit Active Iso Test" 1 "01b = Active Iso Test request" 0 "00b = Active Iso Test not req" ;
VAL_TABLE_ HPDM 3 "11b = Don't care/Take no action" 2 "10b = Execute emergency power-dn" 1 "01b = Execute normal power-down" 0 "00b = Power-down not requested" ;
VAL_TABLE_ HVBCC 3 "11b = Don't care/Take no action" 2 "10b = Emgancy contactor cls req" 1 "01b = Close Contactor" 0 "00b = Open Contactor" ;
VAL_TABLE_ PropB_C0 15 "1111b = Info not available (default)" 11 "1011b = Granted but error" 10 "1010b = Granted" 2 "10b = Denied permanently" 1 "01b = Denied until restart" 0 "00b = Denied due to initialization" ;
VAL_TABLE_ PropB_C1_ErrLvl 7 "111b = Open contactors immediately and lock" 6 "110b = Open contactors immediately" 5 "101b = Open contactors normal" 4 "100b = Open contactors with time limit" 3 "11b = Open contactors with speed limit" 2 "10b = Limp Home with limited power" 1 "01b = Internal information" 0 "00b = System is ok" ;
VAL_TABLE_ PropB_C1_ThermEveStsCellT 3 "11b = info not available (default)" 2 "10b = crit. temp. warn. limit exceeded" 1 "01b = temp. warn. limit exceeded" 0 "00b = temperature ok" ;
VAL_TABLE_ S1_ES_HV_REQ 7 "111b = info not available (default)" 6 "110b = disconnect DC char" 5 "101b = connect für DC char" 4 "100b = prepair for DC char" 3 "11b = connect for AC char" 2 "10b = connect for driving" 1 "01b = emergency disconnect" 0 "00b = disconnect" ;
VAL_TABLE_ PropB_A1_LOCK_ACTIVATED 3 "11b = Not available" 2 "10b = Lock is activated by ESCU" 1 "01b = Lock is activated by HTCU" 0 "00b = Lock is inactive" ;
VAL_TABLE_ PropB_A1_STATE_ES_RELAY 7 "111b = Not available" 6 "110b = Error" 5 "101b = reserved" 4 "100b = Main Relays opening" 3 "11b = Main Relays closed" 2 "10b = All Es-Relays closed" 1 "01b = PreCharge-Relais closed" 0 "00b = All Es-Relays open" ;
VAL_TABLE_ Control_Byte_TP_CM 16 "RTS" 17 "CTS" 19 "EoMA" 20 "ERTS" 21 "ECTS" 22 "EDPO" 23 "EEoMACK" 24 "EAbort" 32 "BAM" 255 "Abort" ;


